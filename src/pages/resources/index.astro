---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const resources = (await getCollection("resources")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="AI Builder Resources"
  description="Read VibeOps Forum primers on vibecoding, agent operations, A2A protocol, and MCP tooling."
>
  <section class="shell py-20">
    <div class="grid gap-10 md:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="mono text-xs uppercase tracking-[0.35em] text-teal-200">Resources</p>
        <h1 class="mt-5 text-5xl font-semibold tracking-[-0.06em] text-white md:text-6xl">A field guide for AI builders.</h1>
      </div>
      <p class="max-w-2xl text-lg leading-8 text-zinc-300">
        These pages give newcomers a shared vocabulary before they join the Slack conversation. They are intentionally practical and meant to grow from community examples.
      </p>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-2">
      {resources.map((resource) => (
        <a href={`/resources/${resource.id}/`} class="group glass rounded-2xl p-6">
          <p class="mono text-xs uppercase tracking-[0.22em] text-teal-200">{resource.data.topic}</p>
          <h2 class="mt-4 text-2xl font-semibold tracking-[-0.04em] text-white group-hover:text-teal-100">{resource.data.title}</h2>
          <p class="mt-3 text-sm leading-6 text-zinc-400">{resource.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

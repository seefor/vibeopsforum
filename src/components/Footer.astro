---
import { SITE, navItems } from "../lib/site";
---

<footer class="border-t border-white/10 bg-[#08060b]/55 py-10">
  <div class="shell grid gap-8 md:grid-cols-[1.2fr_0.8fr]">
    <div>
      <p class="neon-text text-lg font-semibold tracking-tight text-white">VibeOps Forum</p>
      <p class="mt-3 max-w-xl text-sm leading-6 text-zinc-400">
        A practical community for builders working with AI coding agents, agent operations, A2A systems, and MCP tools.
      </p>
    </div>
    <div class="grid grid-cols-2 gap-4 text-sm text-[#cdb8c4] sm:grid-cols-3">
      {navItems.map((item) => <a class="hover:text-white" href={item.href}>{item.label}</a>)}
      <a class="hover:text-white" href={SITE.slackUrl}>Join Slack</a>
    </div>
  </div>
</footer>

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email in ["sif@sifbaksh.com", "ptcapo@gmail.com"];
    }

    match /meetingEvents/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /registrations/{registrationId} {
        allow create: if isSignedIn()
          && registrationId == request.auth.uid
          && request.resource.data.email is string
          && request.resource.data.name is string
          && request.resource.data.createdAt == request.time;
        allow read: if isAdmin() || (isSignedIn() && registrationId == request.auth.uid);
        allow update, delete: if false;
      }

      match /private/{privateDoc} {
        allow read: if isAdmin()
          || (
            isSignedIn()
            && privateDoc == "join"
            && exists(/databases/$(database)/documents/meetingEvents/$(eventId)/registrations/$(request.auth.uid))
          );
        allow write: if isAdmin();
      }
    }
  }
}
